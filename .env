CONTAINER_NAME=docbot-docker
ROS_DOMAIN_ID=0
USE_GPU=false
COMPOSE_PROFILE=linux-gpu
COMPOSE_SERVICE=linux-gpu
USE_SERVICE=false
# RMW: rmw_cyclonedds_cpp or rmw_fastrtps_cpp.
# Fast-DDS is required here because micro-ROS agent is built against FastDDS;
# the rest of the stack must match for discovery to work.
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
